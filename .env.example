# =============================================================================
# keeper — example environment. PLACEHOLDERS ONLY. Never put a real secret here.
# -----------------------------------------------------------------------------
# Real secrets are provided via dev-secret (GPG-encrypted store), NOT this file:
#   run the bot with secrets injected ->  dev-secret run -- just dev
# This file documents WHICH variables exist (env var names referenced from
# spec/config.yaml) so a human knows what to provision. `.env` itself is
# git-ignored; only this `.env.example` is committed (see .gitignore).
# Verify before any commit/release:  ai-secrets-check
# =============================================================================

# --- Telegram USERBOT (the owner's USER account, MTProto/GramJS) -------------
# The community face + sole inbound source. Auth = api id/hash + a SESSION STRING.
# The SESSION STRING is the HIGHEST-VALUE secret in the project: it is full
# control of the owner's personal Telegram account. Never log it, never store it
# in the DB, never echo it. Generate it via an interactive login (see runbook).
TELEGRAM_API_ID=000000                       # from https://my.telegram.org
TELEGRAM_API_HASH=replace_me_api_hash         # from https://my.telegram.org
TELEGRAM_SESSION_STRING=replace_me_session    # full-account credential — top-tier secret

# --- Telegram CONTROL BOT (Bot API/grammY, group admin + owner control plane) -
# Mod executor + owner remote. Auth = bot token. Lower blast radius than the
# session string (revocable via @BotFather), but still a secret.
TELEGRAM_CONTROL_BOT_TOKEN=replace_me_bot_token   # from @BotFather; promote to admin in each channel

# --- LLM provider (OpenAI-compatible; default OpenRouter — see config/bot.yaml) -
LLM_API_KEY=replace_me_llm_key

# --- Content source tokens (one per source in config/sources.yaml that needs auth) ---
# The env var NAME is whatever each source's auth.token_env declares. Example
# from the sample sources.yaml (source id "ai-site-main"):
SITE_MAIN_TOKEN=replace_me_source_token
